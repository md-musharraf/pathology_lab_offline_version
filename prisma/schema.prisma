generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model LabSettings {
  id               Int       @id @default(autoincrement())
  labName          String
  logo             Bytes?    // stored as base64 blob
  address          String
  mobile           String
  email            String?
  website          String?
  gstNumber        String?
  registrationNo   String?
  reportFooter     String?
  doctorName       String?
  signature        Bytes?
  stamp            Bytes?
  printHeader      String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model User {
  id           Int       @id @default(autoincrement())
  name         String
  email        String    @unique
  password     String    // bcrypt hashed
  role         String    @default("RECEPTIONIST") // Role enum
  isActive     Boolean   @default(true)
  lastLogin    DateTime?
  avatar       Bytes?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  activityLogs ActivityLog[]
  patients     Patient[]
}

model Patient {
  id               String    @id  // e.g., LAB-2024-00001
  name             String
  age              Int
  ageUnit          String    @default("YEARS") // AgeUnit enum
  gender           String    // Gender enum
  mobile           String
  email            String?
  address          String?
  bloodGroup       String?
  emergencyContact String?
  referredDoctor   String?
  referredDoctorId Int?
  doctor           Doctor?   @relation(fields: [referredDoctorId], references: [id])
  isEmergency      Boolean   @default(false)
  createdBy        Int
  user             User      @relation(fields: [createdBy], references: [id])
  registeredAt     DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?
  orders           TestOrder[]
  bills            Bill[]
}

model TestCategory {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)
  tests       Test[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Test {
  id               Int           @id @default(autoincrement())
  code             String        @unique  // e.g., CBC001
  name             String
  shortName        String?
  categoryId       Int
  category         TestCategory  @relation(fields: [categoryId], references: [id])
  price            Float
  duration         Int           // TAT in hours
  sampleType       String        // Blood, Urine, Stool, etc.
  container        String?       // EDTA, Plain, etc.
  volume           String?       // 3ml, 5ml
  instructions     String?       // Patient preparation
  methodology      String?
  isActive         Boolean       @default(true)
  isPanel          Boolean       @default(false)  // true = group test
  panelTests       String?       // JSON array of IDs of sub-tests if panel (SQLite doesn't support Int[])
  parameters       TestParameter[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  deletedAt        DateTime?
  orderItems       TestOrderItem[]
}

model TestParameter {
  id              Int       @id @default(autoincrement())
  testId          Int
  test            Test      @relation(fields: [testId], references: [id])
  name            String
  shortName       String?
  unit            String?
  sortOrder       Int       @default(0)
  type            String    @default("NUMERIC") // ParameterType enum
  options         String?   // JSON array for dropdown type
  formula         String?   // for calculated fields
  isHeader        Boolean   @default(false)  // section header row
  refRanges       ReferenceRange[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model ReferenceRange {
  id             Int      @id @default(autoincrement())
  parameterId    Int
  parameter      TestParameter @relation(fields: [parameterId], references: [id])
  gender         String?  // Gender enum, null = both
  ageMin         Int?     // in days for precise matching
  ageMax         Int?
  normalMin      Float?
  normalMax      Float?
  criticalMin    Float?
  criticalMax    Float?
  textNormal     String?  // for text-type parameters
  unit           String?
  interpretation String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model TestOrder {
  id             Int           @id @default(autoincrement())
  orderNo        String        @unique  // LAB-ORD-20240101-0001
  patientId      String
  patient        Patient       @relation(fields: [patientId], references: [id])
  billId         Int?
  bill           Bill?         @relation(fields: [billId], references: [id])
  collectedAt    DateTime?
  expectedAt     DateTime?
  deliveredAt    DateTime?
  priority       String        @default("ROUTINE") // Priority enum
  status         String        @default("PENDING") // OrderStatus enum
  barcodeData    String?       // encoded barcode string
  qrData         String?
  note           String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  items          TestOrderItem[]
  report         Report?
}

model TestOrderItem {
  id          Int         @id @default(autoincrement())
  orderId     Int
  order       TestOrder   @relation(fields: [orderId], references: [id])
  testId      Int
  test        Test        @relation(fields: [testId], references: [id])
  results     TestResult[]
  status      String      @default("PENDING") // ItemStatus enum
  enteredBy   Int?
  verifiedBy  Int?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model TestResult {
  id              Int            @id @default(autoincrement())
  orderItemId     Int
  orderItem       TestOrderItem  @relation(fields: [orderItemId], references: [id])
  parameterId     Int
  numericValue    Float?
  textValue       String?
  status          String         // ResultStatus enum
  flag            String?        // ↑ ↓ !! or null
  isCritical      Boolean        @default(false)
  isAbnormal      Boolean        @default(false)
  note            String?
  enteredAt       DateTime       @default(now())
  enteredBy       Int
}

model Bill {
  id              Int         @id @default(autoincrement())
  billNo          String      @unique
  patientId       String
  patient         Patient     @relation(fields: [patientId], references: [id])
  subtotal        Float
  discountType    String       @default("FLAT") // DiscountType enum
  discountValue   Float       @default(0)
  discountAmount  Float       @default(0)
  gstPercent      Float       @default(0)
  gstAmount       Float       @default(0)
  totalAmount     Float
  paidAmount      Float       @default(0)
  dueAmount       Float       @default(0)
  paymentMethod   String       @default("CASH") // PaymentMethod enum
  paymentStatus   String       @default("UNPAID") // PaymentStatus enum
  referralCommission Float?
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  orders          TestOrder[]
  payments        Payment[]
}

model Payment {
  id        Int      @id @default(autoincrement())
  billId    Int
  bill      Bill     @relation(fields: [billId], references: [id])
  amount    Float
  method    String   // PaymentMethod enum
  reference String?
  paidAt    DateTime @default(now())
  receivedBy Int
}

model Report {
  id          Int       @id @default(autoincrement())
  orderId     Int       @unique
  order       TestOrder @relation(fields: [orderId], references: [id])
  pdfData     Bytes?    // stored PDF blob for caching
  printCount  Int       @default(0)
  approvedBy  Int?
  approvedAt  DateTime?
  deliveredAt DateTime?
  deliveryMethod String? // DeliveryMethod enum
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Doctor {
  id           Int      @id @default(autoincrement())
  name         String
  qualification String?
  hospital     String?
  mobile       String?
  email        String?
  commission   Float    @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  patients     Patient[]
}

model Staff {
  id           Int      @id @default(autoincrement())
  name         String
  role         String   // Role enum
  mobile       String?
  salary       Float?
  joinedAt     DateTime?
  isActive     Boolean  @default(true)
  attendance   Attendance[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Attendance {
  id        Int      @id @default(autoincrement())
  staffId   Int
  staff     Staff    @relation(fields: [staffId], references: [id])
  date      DateTime
  status    String   // AttendanceStatus enum
  inTime    String?
  outTime   String?
  note      String?
}

model InventoryItem {
  id            Int      @id @default(autoincrement())
  name          String
  category      String
  unit          String
  currentStock  Float
  minStock      Float
  maxStock      Float?
  expiryDate    DateTime?
  supplierId    Int?
  supplier      Supplier? @relation(fields: [supplierId], references: [id])
  batchNumber   String?
  purchasePrice Float?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  transactions  InventoryTransaction[]
}

model Supplier {
  id       Int      @id @default(autoincrement())
  name     String
  mobile   String?
  email    String?
  address  String?
  items    InventoryItem[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InventoryTransaction {
  id        Int      @id @default(autoincrement())
  itemId    Int
  item      InventoryItem @relation(fields: [itemId], references: [id])
  type      String   // TxType enum
  quantity  Float
  note      String?
  createdAt DateTime @default(now())
  createdBy Int
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  action    String
  module    String
  details   String?
  ip        String?
  createdAt DateTime @default(now())
}

model BackupLog {
  id         Int      @id @default(autoincrement())
  filename   String
  sizeBytes  Int
  type       String   // BackupType enum
  status     String
  createdAt  DateTime @default(now())
  createdBy  Int
}
